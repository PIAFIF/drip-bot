# Copie ce fichier en .env (local) ou configure-le en secrets GitHub Actions.

# URL du site Drip (par défaut la prod).
DRIP_BASE_URL=https://drip-fr.netlify.app

# Clé partagée = variable INGEST_API_KEY côté Netlify (doit être IDENTIQUE).
INGEST_API_KEY=change-moi-pour-une-longue-chaine-aleatoire

# Flux produits Awin (générés dans Awin → Toolbox → Create-a-Feed), séparés par des virgules.
# Laisse vide tant que tu n'as pas de compte Awin approuvé : la source Awin sera juste ignorée.
AWIN_FEED_URLS=

# Nb max de deals gardés par flux Awin (les mieux réduits) et par exécution.
AWIN_PER_FEED=5
MAX_PER_RUN=20
